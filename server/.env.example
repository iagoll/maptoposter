# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local development (create the DB first: createdb maptoposter)
DATABASE_URL=postgresql://localhost:5432/maptoposter

# Production examples:
# Supabase:  postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
# Railway:   postgresql://postgres:<password>@<host>.railway.app:5432/railway
# Render:    postgresql://user:password@hostname/dbname

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5173

# ── Firebase Admin ────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
